@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .Common {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 20px;
    }

    .tablediv {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        padding: 40px;
        max-width: 700px;
        width: 100%;
    }

    .rowdiv {
        margin-bottom: 15px;
    }

        .rowdiv:first-child {
            font-size: 24px;
            font-weight: 600;
            color: #333;
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 3px solid #667eea;
        }

    .content-box {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 25px;
        background: #f9f9fc;
        margin-top: 20px;
    }

        .content-box p {
            color: #555;
            line-height: 1.6;
            margin-bottom: 20px;
        }

    .celldiv {
        margin-bottom: 15px;
    }

        .celldiv label {
            display: block;
            font-weight: 600;
            color: #444;
            margin-bottom: 8px;
            font-size: 14px;
        }

    input[type="file"] {
        display: none;
    }

    .buttonStyle {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 30px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        width: 200px;
        height: auto;
    }

        .buttonStyle:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.6);
        }

        .buttonStyle:active {
            transform: translateY(0);
        }

    .text-danger {
        margin-top: 15px;
        padding: 10px;
        border-radius: 5px;
        background: #fee;
        color: #c33;
        font-weight: 500;
        display: none;
    }

        .text-danger:not(:empty) {
            display: block;
        }

    .button-container {
        text-align: center;
        margin-top: 25px;
    }

    .file-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        color: #444;
        margin-bottom: 10px;
        font-size: 14px;
    }

    .info-text {
        color: #666;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .option-container {
        background: #f0f0ff;
        border: 2px solid #667eea;
        border-radius: 10px;
        padding: 20px;
        margin: 20px 0;
    }

    .option-title {
        font-weight: 600;
        color: #333;
        margin-bottom: 15px;
        font-size: 16px;
    }

    .radio-option {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
        cursor: pointer;
    }

        .radio-option input[type="radio"] {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            cursor: pointer;
            accent-color: #667eea;
        }

        .radio-option label {
            cursor: pointer;
            color: #555;
            font-size: 14px;
            margin: 0;
        }

        .radio-option:hover label {
            color: #667eea;
        }

    .custom-file-wrapper {
        display: flex;
        align-items: center;
        border: 2px dashed #667eea;
        border-radius: 8px;
        background: white;
        overflow: hidden;
        margin-bottom: 15px;
    }

    .custom-file-btn {
        background: #d1d5db;
        color: white;
        padding: 10px 14px;
        cursor: pointer;
        font-size: 13px;
        white-space: nowrap;
        border: none;
        font-weight: 500;
    }

        .custom-file-btn:hover {
            background: #b0b5be;
            transition: background 0.3s ease;
        }

    .custom-file-name {
        padding: 10px 12px;
        font-size: 13px;
        color: #667eea;
        font-weight: 600;
        flex: 1;
    }

    .signature-section {
        background: #fff3cd;
        border: 2px solid #ffc107;
        border-radius: 10px;
        padding: 20px;
        margin: 20px 0;
    }

    .signature-title {
        font-weight: 600;
        color: #856404;
        margin-bottom: 15px;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .text-input {
        width: 100%;
        padding: 10px 12px;
        font-size: 14px;
        border: 2px solid #ddd;
        border-radius: 6px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        box-sizing: border-box;
        transition: border-color 0.3s ease;
    }

        .text-input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 5px rgba(102, 126, 234, 0.3);
        }

    .helper-text {
        color: #666;
        font-size: 12px;
        margin-top: 5px;
        line-height: 1.5;
    }
</style>

@using (Html.BeginForm("GenerateDocument", "Home", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <div class="Common">
        <div class="tablediv">
            <div class="rowdiv">
                📝 Generate Automated Loan Agreement Document
            </div>

            <div class="content-box">
                <p class="info-text">
                    Generate automated PDF documents using DocIO Library. Upload your Word template and JSON data file to create a professional document instantly.
                </p>

                <div class="rowdiv">
                    <div class="celldiv">
                        <div class="file-label">📄 Select Document Template</div>
                        <div class="custom-file-wrapper">
                            <label class="custom-file-btn" for="file">Choose File</label>
                            <input type="file" id="file" name="file"
                                   accept=".doc,.docx,.rtf,.dot,.dotm,.dotx,.docm,.xml"
                                   onchange="updateFileName(this, 'wordFileName')" />
                            <span class="custom-file-name" id="wordFileName">Template.docx</span>
                        </div>
                    </div>

                    <div class="celldiv">
                        <div class="file-label">📋 Select JSON Data File</div>
                        <div class="custom-file-wrapper">
                            <label class="custom-file-btn" for="jsonFile">Choose File</label>
                            <input type="file" id="jsonFile" name="jsonFile"
                                   accept=".json"
                                   onchange="updateFileName(this, 'jsonFileName')" />
                            <span class="custom-file-name" id="jsonFileName">LoanAgreement.json</span>
                        </div>
                    </div>

                    <div class="celldiv" style="margin: 20px 0;">
                        <div class="radio-option">
                            <input type="checkbox"
                                   id="enableDigitalSign"
                                   name="enableDigitalSign"
                                   value="true"
                                   onchange="toggleSignatureSection()"
                                   style="width: 20px; height: 20px; margin-right: 10px; cursor: pointer; accent-color: #667eea;" />
                            <input type="hidden" name="enableDigitalSign" value="false" />
                            <label for="enableDigitalSign" style="cursor: pointer; color: #555; font-size: 16px; font-weight: 600; margin: 0;">✍️ Enable Digital Signature</label>
                        </div>
                    </div>

                    <div class="signature-section" id="signatureSection" style="display: none;">
                        <div class="signature-title">✍️ Digital Signature Configuration (Optional)</div>

                        <div class="celldiv">
                            <div class="file-label">🖼️ Signature Image File</div>
                            <div class="custom-file-wrapper">
                                <label class="custom-file-btn" for="signatureImage">Choose File</label>
                                <input type="file" id="signatureImage" name="signatureImage"
                                       accept=".png,.jpg,.jpeg,.gif,.bmp"
                                       onchange="updateFileName(this, 'signatureImageName')" />
                                <span class="custom-file-name" id="signatureImageName">Signature.png</span>
                            </div>
                            <div class="helper-text">
                                💡 Upload a custom signature image (PNG, JPG, etc.). If no image is uploaded, the default signature will be placed above the specified keywords in the document.
                            </div>
                        </div>

                        <div class="celldiv">
                            <div class="file-label">🔍 Signature Placeholder Keywords</div>
                            <input type="text"
                                   name="signatureKeywords"
                                   id="signatureKeywords"
                                   class="text-input"
                                   placeholder="e.g., Signature, AuthorizedSign"
                                   value="Sign, WITNESS, AuthorizedSign, Signature" />
                            <div class="helper-text">
                                💡 Enter keywords separated by commas to identify where signatures should be placed in your document. Default: "Sign, WITNESS, AuthorizedSign"
                            </div>
                        </div>
                        <div class="helper-text" style="background: #fff9e6; padding: 12px; border-left: 4px solid #ffc107; margin-bottom: 15px; border-radius: 4px;">
                            📌 <strong>Note:</strong> Digital signatures will be automatically placed <strong>above</strong> the keywords you specify in your document. If the keywords are not found in the document, the signature will not be inserted in the PDF.
                        </div>
                    </div>

                    <div class="option-container">
                        <div class="option-title">📄 Output Options:</div>

                        <div class="radio-option">
                            <input type="radio" id="singlePDF" name="outputType" value="single" checked />
                            <label for="singlePDF">Generate all documents as a single PDF</label>
                        </div>

                        <div class="radio-option">
                            <input type="radio" id="multiplePDF" name="outputType" value="multiple" />
                            <label for="multiplePDF">Generate each record as a separate PDF document</label>
                        </div>
                    </div>

                    <div class="button-container">
                        <input class="buttonStyle" type="submit" value="Generate Document" name="button" />

                        <div class="text-danger">
                            @ViewBag.Message
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    function updateFileName(input, spanId) {
        const span = document.getElementById(spanId);
        if (input.files && input.files.length > 0) {
            span.textContent = input.files[0].name;
        } else {
            // Reset to default name if no file selected
            if (spanId === 'wordFileName') {
                span.textContent = 'Template.docx';
            } else if (spanId === 'jsonFileName') {
                span.textContent = 'LoanAgreement.json';
            } else if (spanId === 'signatureImageName') {
                span.textContent = 'Signature.png';
            }
        }
    }

    function toggleSignatureSection() {
        const checkbox = document.getElementById('enableDigitalSign');
        const signatureSection = document.getElementById('signatureSection');

        if (checkbox.checked) {
            signatureSection.style.display = 'block';
        } else {
            signatureSection.style.display = 'none';
            // Reset signature fields when disabled
            document.getElementById('signatureImage').value = '';
            document.getElementById('signatureImageName').textContent = 'Signature.png';
            document.getElementById('signatureKeywords').value = 'Sign, WITNESS, AuthorizedSign';
        }
    }
</script>